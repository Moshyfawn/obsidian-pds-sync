{
  "name": "obsidian-pds-sync",
  "version": "0.1.0",
  "description": "Sync your Obsidian vault to an atproto PDS.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "bun esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && bun esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "atproto",
    "pds",
    "standard.site",
    "sync"
  ],
  "license": "MIT",
  "dependencies": {
    "@atcute/client": "5.0.0",
    "@atcute/identity-resolver": "2.0.0",
    "@atcute/oauth-browser-client": "4.0.0",
    "@atcute/password-session": "1.0.0",
    "hash-wasm": "4.12.0"
  },
  "devDependencies": {
    "@atcute/atproto": "4.0.2",
    "@types/node": "^22.0.0",
    "esbuild": "0.28.0",
    "obsidian": "1.13.1",
    "typescript": "6.0.3"
  }
}
